rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // HELPER FUNCTIONS
    // =============================================

    // Check if the requesting user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the requesting user is the document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the requesting user has admin role
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =============================================
    // USERS COLLECTION
    // =============================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Users can only create their own profile during registration
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']);

      // Users can update their own profile (except role)
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid']);

      allow delete: if false;
    }

    // =============================================
    // ISSUES COLLECTION
    // =============================================
    match /issues/{issueId} {
      // Users can read their own issues, admins can read all
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // Authenticated users can create issues
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'Pending';

      // Users can update their own issues (e.g., soft deleting), admins can update any issue
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // No physical deletes from client (enforce soft delete)
      allow delete: if false;
    }

    // =============================================
    // PUBLIC ISSUES COLLECTION
    // =============================================
    match /publicIssues/{ticketId} {
      // Anyone can fetch status tracking info by ticketId (get), but cannot search/list (list)
      allow get: if true;
      allow list: if false;

      // Only authenticated users can write/update (transactions for creating/updating status)
      allow write: if isAuthenticated();
    }

    // =============================================
    // COUNTERS COLLECTION
    // =============================================
    match /counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // STATS COLLECTION
    // =============================================
    match /stats/{statId} {
      // Authenticated users can read stats, updates are done via transactions during issue creation/updates
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // CATEGORIES COLLECTION
    // =============================================
    match /categories/{categoryId} {
      // Anyone can read active categories (needed for issue reporting form)
      allow read: if true;
      // Only admins can manage categories
      allow write: if isAdmin();
    }
  }
}
